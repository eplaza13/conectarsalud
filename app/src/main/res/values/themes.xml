<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.ConectarSalud" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary -->
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryVariant">@color/purple_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary -->
        <item name="colorSecondary">@color/purple_light</item>
        <item name="colorSecondaryVariant">@color/purple_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Surface -->
        <item name="colorSurface">@color/white</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <!-- Background -->
        <item name="colorBackground">@color/background_light</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="android:colorBackground">@color/background_light</item>
        <item name="android:windowBackground">@color/background_light</item>
        <!-- Error -->
        <item name="colorError">@color/error</item>
        <!-- Status bar -->
        <item name="android:statusBarColor">@color/purple_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
        <!-- Font -->
        <item name="android:fontFamily">sans-serif</item>
        <!-- Ripple -->
        <item name="rippleColor">@color/purple_lighter</item>
    </style>

    <!-- Auth screens with transparent status bar -->
    <style name="Theme.ConectarSalud.Auth" parent="Theme.ConectarSalud">
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- TextAppearances -->
    <style name="TextAppearance.ConectarSalud.H1" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">32sp</item>
    </style>

    <style name="TextAppearance.ConectarSalud.H2" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
    </style>

    <style name="TextAppearance.ConectarSalud.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Button style -->
    <style name="Widget.ConectarSalud.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
    </style>
</resources>
