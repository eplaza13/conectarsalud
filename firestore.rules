# ConectarSalud — Reglas de Seguridad para Firestore
# Copiar y pegar en Firebase Console → Firestore → Reglas

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users: solo el propio usuario puede leer/escribir su perfil
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Turnos: solo el propietario puede leer/crear/actualizar sus turnos
    match /turnos/{turnoId} {
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      allow read, update: if request.auth != null
        && resource.data.userId == request.auth.uid;

      allow delete: if false; // No se permite borrar, solo cancelar
    }
  }
}
